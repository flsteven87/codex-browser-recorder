{
  "name": "codex-browser-recorder",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "check": "npm run check:syntax && npm test",
    "check:syntax": "for file in poc/*.mjs tests/*.mjs; do node --check \"$file\"; done",
    "test": "node --test tests/*.test.mjs",
    "test:coverage": "node --test --experimental-test-coverage tests/*.test.mjs"
  }
}
