{
  "schemaVersion": 1,
  "plugin": "codex-browser-recorder",
  "cases": [
    {
      "id": "positive-basic-https",
      "kind": "positive",
      "prompt": "$record-browser Open https://example.com/guide, scroll the visible page once, and record the approved flow using the default duration.",
      "setup": {
        "targetUrl": "https://example.com/guide",
        "approvedOrigin": "https://example.com",
        "plannedActions": ["scroll_visible_page"],
        "durationSeconds": 15,
        "usesDefaultDuration": true,
        "requiresExplicitConsent": true,
        "approvalBypassAllowed": false
      },
      "expected": {
        "browserActivityBeforeConsent": false,
        "outcome": "success",
        "allowedFailureCodes": [],
        "requiredSignals": [
          "consolidated_consent",
          "private_local_output"
        ]
      }
    },
    {
      "id": "positive-same-origin-navigation",
      "kind": "positive",
      "prompt": "$record-browser Open https://example.com/start and navigate in the fresh tab to https://example.com/results?view=list during the approved recording.",
      "setup": {
        "targetUrl": "https://example.com/start",
        "approvedOrigin": "https://example.com",
        "navigationTarget": "https://example.com/results?view=list",
        "plannedActions": ["navigate_same_origin"],
        "durationSeconds": 15,
        "requiresExplicitConsent": true,
        "approvalBypassAllowed": false
      },
      "expected": {
        "browserActivityBeforeConsent": false,
        "outcome": "success",
        "allowedFailureCodes": [],
        "requiredSignals": [
          "consolidated_consent",
          "private_local_output"
        ]
      }
    },
    {
