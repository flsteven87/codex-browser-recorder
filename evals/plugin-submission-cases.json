{
  "schemaVersion": 1,
  "plugin": "codex-browser-recorder",
  "fixtures": {
    "w3c-pointer-events": {
      "authentication": "none",
      "instructions": "No setup required; open the public HTTPS page.",
      "url": "https://www.w3.org/TR/pointerevents/"
    }
  },
  "cases": [
    {
      "id": "positive-basic-https",
      "kind": "positive",
      "prompt": "$record-browser Open https://www.w3.org/TR/pointerevents/, scroll the visible page once, and record the approved flow using the default duration.",
      "setup": {
        "fixtureId": "w3c-pointer-events",
        "targetUrl": "https://www.w3.org/TR/pointerevents/",
        "approvedOrigin": "https://www.w3.org",
        "plannedActions": ["scroll_visible_page"],
        "durationSeconds": 15,
        "usesDefaultDuration": true,
        "requiresExplicitConsent": true,
        "approvalBypassAllowed": false
      },
      "expected": {
        "browserActivityBeforeConsent": false,
        "outcome": "success",
        "allowedFailureCodes": [],
        "requiredSignals": [
          "consolidated_consent",
          "saved_recording_destination",
          "h264_mp4"
        ],
        "reviewerExpectation": "A validated Saved Recording is published only after the approved scroll produces new observed pointer evidence."
      }
    },
    {
      "id": "positive-same-origin-navigation",
      "kind": "positive",
