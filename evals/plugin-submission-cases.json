    {
      "id": "positive-maximum-duration",
      "kind": "positive",
      "prompt": "$record-browser Open https://example.net/demo, scroll the visible page once, and record the approved flow for 60 seconds without changing the hard limit.",
      "setup": {
        "targetUrl": "https://example.net/demo",
        "approvedOrigin": "https://example.net",
        "plannedActions": ["scroll_visible_page"],
