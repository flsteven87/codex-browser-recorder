      "expected": {
        "browserActivityBeforeConsent": false,
        "outcome": "success",
        "allowedFailureCodes": [],
        "requiredSignals": [
          "consolidated_consent",
          "saved_recording_destination",
          "h264_mp4"
        ],
        "reviewerExpectation": "The same-origin fragment navigation remains inside the approved Recording Session and publishes one Saved Recording."
      }
    },
