      "setup": {
        "fixtureId": "w3c-pointer-events",
        "targetUrl": "https://www.w3.org/TR/pointerevents/",
        "approvedOrigin": "https://www.w3.org",
        "navigationTarget": "https://www.w3.org/TR/pointerevents/#intro",
        "plannedActions": ["navigate_same_origin"],
        "destinationKind": "desktop",
